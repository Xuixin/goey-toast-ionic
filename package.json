{
  "name": "goey-toast-ng",
  "version": "1.0.0",
  "description": "Organic blob morph toast notifications for Ionic Angular — a port of goey-toast",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Xuixin/goey-toast-ionic.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "@angular/common": ">=15.0.0",
    "@angular/core": ">=15.0.0",
    "rxjs": ">=7.0.0"
  },
  "keywords": [
    "angular",
    "ionic",
    "toast",
    "notification",
    "animation",
    "blob",
    "morph"
  ],
  "module": "fesm2022/goey-toast-ng.mjs",
  "typings": "index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./index.d.ts",
      "esm2022": "./esm2022/goey-toast-ng.mjs",
      "esm": "./esm2022/goey-toast-ng.mjs",
      "default": "./fesm2022/goey-toast-ng.mjs"
    }
  },
  "sideEffects": false,
  "dependencies": {
    "tslib": "^2.3.0"
  }
}